{
  "name": "mini-shiki",
  "version": "4.3.0",
  "type": "module",
  "repository": "git+https://github.com/un-ts/mini-shiki.git",
  "homepage": "https://github.com/un-ts/mini-shiki#readme",
  "funding": "https://opencollective.com/mini-shiki",
  "license": "MIT",
  "packageManager": "yarn@4.17.0",
  "exports": {
    ".": {
      "types": "./dist/shiki.d.mts",
      "default": "./dist/shiki.mjs"
    },
    "./onig.wasm": {
      "import": "./dist/onig.wasm"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "static"
  ],
  "scripts": {
    "build": "tsdown && cp src/onig.wasm dist/onig.wasm",
    "format": "prettier --write .",
    "lint": "run-p 'lint:*'",
    "lint:es": "eslint",
    "lint:tsc": "tsc --noEmit",
    "prepare": "cp node_modules/shiki/dist/onig.wasm src/onig.wasm && simple-git-hooks && yarn-berry-deduplicate || exit 0",
    "release": "yarn build && clean-pkg-json && changeset publish",
    "test": "c8 --reporter=lcov --reporter=text node --experimental-require-module --experimental-strip-types --test",
    "typecov": "type-coverage",
    "version": "changeset version && yarn --no-immutable"
  },
  "dependencies": {
    "@shikijs/engine-oniguruma": "^4.3.0",
    "@shikijs/langs": "^4.3.0",
    "@shikijs/themes": "^4.3.0",
    "@shikijs/types": "^4.3.0",
    "@shikijs/vscode-textmate": "^10.0.2"
  },
  "devDependencies": {
    "@1stg/common-config": "^15.0.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@types/node": "^25.9.2",
    "c8": "^11.0.0",
    "clean-pkg-json": "^2.0.0",
    "eslint": "^10.4.1",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^9.0.1",
    "prettier": "^3.8.4",
    "semver": "7.8.5",
    "shiki": "^4.3.0",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.22.2",
    "type-coverage": "^2.29.7",
    "typescript": "^6.0.3",
    "yarn-berry-deduplicate": "^6.1.3"
  },
  "resolutions": {
    "prettier": "^3.8.4"
  },
  "typeCoverage": {
    "atLeast": 100,
    "cache": true,
    "detail": true,
    "ignoreAsAssertion": true,
    "ignoreFiles": [
      "dist/*.d.mts"
    ],
    "ignoreNonNullAssertion": true,
    "showRelativePath": true,
    "strict": true,
    "update": true
  }
}
